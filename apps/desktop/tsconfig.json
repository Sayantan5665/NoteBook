{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@notebook/ipc-contracts": ["../../packages/ipc-contracts/src"],
      "@notebook/ipc-contracts/*": ["../../packages/ipc-contracts/src/*"],
      "@notebook/shared-types": ["../../packages/shared-types/src"],
      "@notebook/shared-types/*": ["../../packages/shared-types/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "electron"]
}
